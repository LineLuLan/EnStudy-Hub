# ============================================================
# EnStudy-Hub — Environment variables template
# ------------------------------------------------------------
# Copy this file to .env.local and fill values.
# NEVER commit .env.local (already in .gitignore).
# See docs/API_KEYS.md for how to obtain each value.
# ============================================================

# --- Supabase (BẮT BUỘC từ Tuần 1) -------------------------
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"

# SERVER-ONLY — bypass RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# Drizzle / direct Postgres connection — use Supabase pooler (port 6543)
# Supabase Dashboard → Project Settings → Database → Connection pooling
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# --- Google OAuth (Optional — Tuần 1 nếu cần Google login) ---
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# --- App ---------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
